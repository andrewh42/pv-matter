# pv-matter configuration (systemd EnvironmentFile: KEY=VALUE, no `export`).
# install.sh writes the real file to /etc/pv-matter/config.env (mode 0600).

# MQTT broker sma-daemon publishes to. Host is required; port defaults to 1883.
PV_MQTT_HOST=localhost
#PV_MQTT_PORT=1883

# Broker credentials. Omit both to connect anonymously (fine for a broker
# bound to localhost); set both when mosquitto has allow_anonymous false.
#PV_MQTT_USERNAME=pv-matter
#PV_MQTT_PASSWORD=change-me

# Optional overrides (defaults shown):
# Topic root — must match sma-daemon's MQTT_TOPIC_PREFIX.
#PV_MQTT_TOPIC_PREFIX=pv-inverter
# Pin a specific publisher device id (default: lock onto the first one seen).
#PV_DEVICE_ID=sma-sb5000tl-2130012345
# Matter fabric storage (the unit sets this to /var/lib/pv-matter).
#PV_STORAGE_PATH=/var/lib/pv-matter
# Matter operational UDP port (advertised over mDNS, so controllers still find
# it). Override to run a second pv-matter daemon on the same host.
#PV_MATTER_PORT=5540
# Seconds to wait for the retained info topic before starting with a
# placeholder identity.
#PV_BOOTSTRAP_TIMEOUT=30
#RUST_LOG=info
# Capture a backtrace in each rs-matter Error (logged as "disabled backtrace"
# without this). Captures on every error, including ones never logged — turn it
# on for debugging, not steady state.
#RUST_BACKTRACE=1
